{
  "manifest_version": 3,
  "name": "LinkPilot AI",
  "version": "1.2.0",
  "description": "AI-powered LinkedIn intelligence for B2B sales, freelancing, and job search. Score prospects, personalise outreach, and generate posts — by Satyron Private Limited.",
  "permissions": ["storage", "activeTab", "clipboardWrite", "identity"],
  "oauth2": {
    "client_id": "592927077998-058seb6htaan8ma47vhhiqjg724avke3.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "https://api.hubapi.com/*",
    "https://www.googleapis.com/*",
    "https://hokgbtrptddjgwgvvhrb.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "LinkPilot AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
