{
  "manifest_version": 3,
  "name": "Husnain LinkedIn Helper",
  "version": "1.1.0",
  "description": "AI-powered LinkedIn prospecting — score profiles against your ideal customer profile, get industry-fit insights, and personalized outreach.",
  "permissions": ["storage", "activeTab", "clipboardWrite"],
  "host_permissions": ["https://www.linkedin.com/*", "https://api.openai.com/*", "https://api.hubapi.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Husnain LinkedIn Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
