{
  "manifest_version": 3,
  "name": "LinkPilot AI",
  "version": "1.2.0",
  "key": "",
  "description": "AI-powered LinkedIn intelligence for B2B sales, freelancing, and job search. Score prospects, personalise outreach, and generate posts — by Satyron Private Limited.",
  "permissions": ["storage", "activeTab", "clipboardWrite", "identity", "declarativeNetRequest"],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "stripe_redirects",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "oauth2": {
    "client_id": "592927077998-058seb6htaan8ma47vhhiqjg724avke3.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "https://api.hubapi.com/*",
    "https://www.googleapis.com/*",
    "https://hokgbtrptddjgwgvvhrb.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content/index.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "LinkPilot AI",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/extension_icon.png",
      "48": "assets/extension_icon.png",
      "128": "assets/extension_icon.png"
    }
  },
  "icons": {
    "16": "assets/extension_icon.png",
    "48": "assets/extension_icon.png",
    "128": "assets/extension_icon.png"
  }
}
